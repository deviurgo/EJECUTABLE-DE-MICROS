#include <LiquidCrystal_I2C.h>
LiquidCrystal_I2C pantalla(0x27,16,2);
#include <Wire.h>
//bt
#include <SoftwareSerial.h>
SoftwareSerial BT(11,10);
char comando;
//pinout del l293d
int IN1=3;
int IN2=4;
int EN1=2;
int IN3=6;
int IN4=7;
int EN2=5;

void setup() {
 
  // Inicializador de pantalla LCD
pantalla.init();
pantalla.begin(16,1);
pantalla.backlight();
pantalla.clear();
pantalla.setCursor(0,0);
pantalla.print("Sistema Robotico");
pantalla.setCursor(0, 1);
pantalla.print("motores");
//driver l293d
pinMode(IN1, OUTPUT);
pinMode(IN2, OUTPUT);
pinMode(EN1, OUTPUT);
pinMode(IN3, OUTPUT);
pinMode(IN4, OUTPUT);
pinMode(IN2, OUTPUT);

//Bluetooth HC05
BT.begin(9600);
Serial.begin(9600);
Serial.println("LIsto");
}

void loop() {
  //lcd
pantalla.display();
delay(5000);
pantalla.clear();

//bt
if (BT.available()) {
  comando=BT.read();
  BT.write(comando);
  Serial.print("Recibido ");
  Serial.println(comando);
if (Serial.available()){
  BT.write(Serial.read());
}
}
  if (comando=='A'){
    pantalla.print("Avanzando");
digitalWrite(EN1, HIGH);
digitalWrite(EN2, HIGH);
digitalWrite(IN1, HIGH);
digitalWrite(IN2, LOW);
digitalWrite(IN3, HIGH);
digitalWrite(IN4, LOW);
delay(1000);
}
 if (comando=='B'){
  pantalla.print("Retrocediendo");
digitalWrite(EN1, HIGH);
digitalWrite(EN2, HIGH);
digitalWrite(IN1, LOW);
digitalWrite(IN2, HIGH);
digitalWrite(IN3, LOW);
digitalWrite(IN4, HIGH);
delay(1000);
}
if (comando=='C'){
  pantalla.print("GiroIzquierda");
digitalWrite(EN1, HIGH);
digitalWrite(EN2, LOW);
digitalWrite(IN1, HIGH);
digitalWrite(IN2, LOW);
digitalWrite(IN3, LOW);
digitalWrite(IN4, LOW);
delay(1000);
}
if (comando=='D'){
  pantalla.print("GiroDerecha");
digitalWrite(EN1, LOW);
digitalWrite(EN2, HIGH);
digitalWrite(IN1, LOW);
digitalWrite(IN2, LOW);
digitalWrite(IN3, HIGH);
digitalWrite(IN4, LOW);
delay(1000);
}
else {
  pantalla.print("Estacionado");
digitalWrite(EN1, LOW);
digitalWrite(EN2, LOW);
digitalWrite(IN1, LOW);
digitalWrite(IN2, LOW);
digitalWrite(IN3, LOW);
digitalWrite(IN4, LOW);
}
}
